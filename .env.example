# =============================================================================
# POC-AMS Root Environment Variables
# Aligned with FRD Section 4 Technology Stack
# =============================================================================

# --- PostgreSQL 16 (FRD Section 4.6) ---
DATABASE_URL=postgresql://poc_user:poc_password@localhost:5432/poc_ams

# --- Redis 7 (FRD Section 4.7) ---
REDIS_URL=redis://localhost:6379

# --- RS256 JWT Authentication (FRD Section 5.3) ---
# Auth uses asymmetric RS256 keys, NOT symmetric secrets
# Generate keypair: openssl genrsa -out private.pem 2048
#                   openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL=7d

# --- MinIO (FRD Section 4.8) ---
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=poc_minio_user
MINIO_SECRET_KEY=poc_minio_password

# --- LiveKit SFU (FRD Section 4.4) ---
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=<your_livekit_api_key>
LIVEKIT_API_SECRET=<your_livekit_api_secret>

# --- Ollama Local LLM (FRD Section 4.5) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3:8b

# --- Meilisearch (FRD Section 4.9) ---
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_KEY=poc_meili_master_key

# --- Telebirr / CBE Birr E-Payment (FRD Section 12.3) ---
TELEBIRR_APP_ID=<your_telebirr_app_id>
TELEBIRR_APP_KEY=<your_telebirr_app_key>
TELEBIRR_SHORT_CODE=<your_telebirr_short_code>
TELEBIRR_PUBLIC_KEY=<your_telebirr_public_key>
CBE_BIRR_MERCHANT_ID=<your_cbe_birr_merchant_id>
CBE_BIRR_API_KEY=<your_cbe_birr_api_key>
