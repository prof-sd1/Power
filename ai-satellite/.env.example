# AI Satellite Environment Variables
AI_PORT=8001

# Ollama Configuration (FRD Section 4.5 — Local LLM, zero internet)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3:8b

# PostgreSQL + pgvector (schema_ai)
DATABASE_URL=postgresql+asyncpg://poc_user:poc_password@localhost:5432/poc_ams

# Academic Core URL (for CORS)
ACADEMIC_CORE_URL=http://localhost:8000

# RS256 Public Key for JWT Verification (FRD Section 5.3)
JWT_PUBLIC_KEY=
