# Real-Time Engine Environment Variables
RT_PORT=3001
REDIS_URL=redis://localhost:6379
FRONTEND_URL=http://localhost:3000

# LiveKit Configuration (FRD Section 4.4)
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret
LIVEKIT_HOST=http://localhost:7880

# RS256 Public Key for JWT Verification (FRD Section 5.3)
# Paste the PEM-encoded public key here
JWT_PUBLIC_KEY=
